# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use '*' to allow all (dev only).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Image Storage ────────────────────────────────────────────────────────────
# Absolute or relative path where processed WebP images will be saved.
# Default: packages/backend/public/images
OUTPUT_DIR=./public/images

# Public base URL where processed images are served.
# In production, replace with your CDN or S3 public URL:
#   e.g. https://d1abc123.cloudfront.net
#   e.g. https://my-bucket.s3.eu-west-1.amazonaws.com/property-images
IMAGES_BASE_URL=http://localhost:4000/images

# ─── Upload Limits ────────────────────────────────────────────────────────────
# Maximum upload size in bytes (default: 50 MB).
MAX_FILE_SIZE_BYTES=52428800
