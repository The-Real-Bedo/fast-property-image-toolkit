{
  "name": "fast-property-image-toolkit",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end image pipeline — WebP conversion, lazy loading & progressive blur rendering",
  "workspaces": [
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/backend",
